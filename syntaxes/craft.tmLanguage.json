{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Craft",
    "scopeName": "source.craft",
    "fileTypes": [".craft"],
    "patterns": [
        { "include": "#comment" },
        { "include": "#string" },
        { "include": "#actor-declaration" },
        { "include": "#domain-declaration" },
        { "include": "#service-declaration" },
        { "include": "#use-case-declaration" },
        { "include": "#block-keywords" },
        { "include": "#flow-keyword" },
        { "include": "#action-verbs" },
        { "include": "#connector-keywords" },
        { "include": "#actor-types" },
        { "include": "#property-keywords" },
        { "include": "#section-keywords" },
        { "include": "#entity-name" },
        { "include": "#number" },
        { "include": "#boolean" },
        { "include": "#punctuation" }
    ],
    "repository": {
        "comment": {
            "patterns": [
                {
                    "name": "comment.line.double-slash",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "string": {
            "name": "string.quoted.double",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape",
                    "match": "\\\\."
                }
            ]
        },
        "actor-declaration": {
            "match": "^\\s*(actor)\\s+(user|system|service)\\s+([A-Z][A-Za-z0-9_]*)",
            "captures": {
                "1": { "name": "storage.type" },
                "2": { "name": "support.type" },
                "3": { "name": "entity.name.type" }
            }
        },
        "domain-declaration": {
            "match": "^\\s*(domain)\\s+([A-Z][A-Za-z0-9_]*)",
            "captures": {
                "1": { "name": "storage.type" },
                "2": { "name": "entity.name.type" }
            }
        },
        "service-declaration": {
            "match": "^\\s*(service)\\s+([A-Z][A-Za-z0-9_]*)",
            "captures": {
                "1": { "name": "storage.type" },
                "2": { "name": "entity.name.type" }
            }
        },
        "use-case-declaration": {
            "match": "^\\s*(use_case)\\s+(\"[^\"]*\")",
            "captures": {
                "1": { "name": "storage.type" },
                "2": { "name": "string.quoted.double" }
            }
        },
        "block-keywords": {
            "match": "\\b(services|domains|actors|arch|exposure)\\b",
            "captures": {
                "1": { "name": "keyword.other" }
            }
        },
        "flow-keyword": {
            "match": "^\\s*(when)\\b",
            "captures": {
                "1": { "name": "keyword.control" }
            }
        },
        "action-verbs": {
            "match": "\\b(asks|notifies|listens|returns|marks)\\b",
            "captures": {
                "1": { "name": "entity.name.function" }
            }
        },
        "connector-keywords": {
            "match": "\\b(to|through)\\b",
            "captures": {
                "1": { "name": "keyword.operator" }
            }
        },
        "actor-types": {
            "match": "\\b(user|system|service)\\b",
            "captures": {
                "1": { "name": "support.type" }
            }
        },
        "property-keywords": {
            "match": "\\b(contexts|language|data-stores|deployment|to|through)\\s*:",
            "captures": {
                "1": { "name": "keyword.other" }
            }
        },
        "section-keywords": {
            "match": "\\b(presentation|gateway)\\s*:",
            "captures": {
                "1": { "name": "keyword.other" }
            }
        },
        "entity-name": {
            "name": "entity.name.type",
            "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        },
        "number": {
            "name": "constant.numeric",
            "match": "\\b[0-9]+(\\.[0-9]+)?(%)?\\b"
        },
        "boolean": {
            "name": "constant.language",
            "match": "\\b(true|false)\\b"
        },
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.definition.block",
                    "match": "[{}]"
                },
                {
                    "name": "punctuation.separator",
                    "match": ","
                },
                {
                    "name": "punctuation.separator",
                    "match": ":"
                },
                {
                    "name": "punctuation.operator",
                    "match": "->"
                },
                {
                    "name": "punctuation.operator",
                    "match": ">"
                },
                {
                    "name": "punctuation.bracket",
                    "match": "[()]"
                }
            ]
        }
    }
}
