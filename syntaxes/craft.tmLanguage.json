{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Craft",
    "scopeName": "source.craft",
    "fileTypes": [".craft"],
    "patterns": [
        { "include": "#comment" },
        { "include": "#string" },
        { "include": "#block-keywords" },
        { "include": "#domain-block-keyword" },
        { "include": "#service-block-keyword" },
        { "include": "#actor-block-keyword" },
        { "include": "#property-keywords" },
        { "include": "#action-verbs" },
        { "include": "#actor-types" },
        { "include": "#section-keywords" },
        { "include": "#use-case-title" },
        { "include": "#number" },
        { "include": "#boolean" },
        { "include": "#punctuation" },
        { "include": "#identifier" }
    ],
    "repository": {
        "comment": {
            "patterns": [
                {
                    "name": "comment.line.double-slash",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "string": {
            "name": "string.quoted.double",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape",
                    "match": "\\\\."
                }
            ]
        },
        "use-case-title": {
            "match": "(use_case)\\s+(\"[^\"]*\")",
            "captures": {
                "1": { "name": "keyword.control" },
                "2": { "name": "string.quoted" }
            }
        },
        "block-keywords": {
            "match": "\\b(services|domains|actors|arch|exposure|use_case|when)\\b",
            "captures": {
                "1": { "name": "keyword.control" }
            }
        },
        "service-block-keyword": {
            "match": "^\\s*(service)\\b",
            "captures": {
                "1": { "name": "keyword.control" }
            }
        },
        "domain-block-keyword": {
            "match": "^\\s*(domain)\\b",
            "captures": {
                "1": { "name": "keyword.control" }
            }
        },
        "actor-block-keyword": {
            "match": "^\\s*(actor)\\b",
            "captures": {
                "1": { "name": "keyword.control" }
            }
        },
        "property-keywords": {
            "match": "\\b(contexts|language|data-stores|deployment|to|through)\\s*:",
            "captures": {
                "1": { "name": "keyword.other" }
            }
        },
        "section-keywords": {
            "match": "\\b(presentation|gateway)\\s*:",
            "captures": {
                "1": { "name": "keyword.other" }
            }
        },
        "action-verbs": {
            "match": "\\b(asks|notifies|listens|returns)\\b",
            "captures": {
                "1": { "name": "entity.name.function" }
            }
        },
        "actor-types": {
            "match": "\\b(user|system|service)\\b",
            "captures": {
                "1": { "name": "support.type" }
            }
        },
        "number": {
            "name": "constant.numeric",
            "match": "\\b[0-9]+(\\.[0-9]+)?(%)?\\b"
        },
        "boolean": {
            "name": "constant.language",
            "match": "\\b(true|false)\\b"
        },
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.operator",
                    "match": "[{}]"
                },
                {
                    "name": "punctuation.operator",
                    "match": ","
                },
                {
                    "name": "punctuation.operator",
                    "match": ":"
                },
                {
                    "name": "punctuation.operator",
                    "match": "->"
                },
                {
                    "name": "punctuation.operator",
                    "match": ">"
                },
                {
                    "name": "punctuation.bracket",
                    "match": "[()]"
                }
            ]
        },
        "identifier": {
            "name": "variable.other",
            "match": "[A-Za-z_][A-Za-z0-9_-]*"
        }
    }
}
