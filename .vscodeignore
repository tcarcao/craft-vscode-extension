# Exclude everything except what we explicitly allow
**/*

# Bundled distribution files (client, webviews, static assets, and Go binary)
!dist/**

# TextMate grammar for baseline syntax highlighting (S2 / Q6)
!syntaxes/**

# Essential config files
!package.json
!language-configuration.json
!LICENSE
!README.md

# Icons
!resources/craft_icon.png
!resources/craft_icon.svg

# Exclude source maps and old build artifacts
dist/**/*.map
dist/server.js
dist/server.js.map
dist/node_modules/**
