{
    "name": "craft-arch-diagrams",
    "displayName": "Craft Arch Diagrams",
    "description": "Syntax highlighting, language server, and visual diagram generation for the Craft architecture modeling language",
    "version": "0.1.11",
    "lspVersion": "2.8.1",
    "publisher": "tcarcao",
    "icon": "resources/craft_icon.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/tcarcao/craft-vscode-extension.git"
    },
    "bugs": {
        "url": "https://github.com/tcarcao/craft-vscode-extension/issues"
    },
    "homepage": "https://github.com/tcarcao/craft-vscode-extension#readme",
    "license": "MIT",
    "keywords": [
        "craft",
        "architecture",
        "modeling",
        "dsl",
        "c4",
        "diagrams",
        "domain-driven-design",
        "ddd"
    ],
    "main": "./dist/client.js",
    "engines": {
        "vscode": "^1.75.0"
    },
    "dependencies": {
        "axios": "^1.0.0",
        "glob": "^11.0.3",
        "mermaid": "^10.9.6",
        "vscode-languageclient": "^9.0.1",
        "vscode-uri": "^3.1.0"
    },
    "scripts": {
        "vscode:prepublish": "npm run bundle",
        "compile": "tsc -b && cd client && npm run compile",
        "watch": "tsc -b -w",
        "lint": "eslint",
        "test": "jest",
        "postinstall": "cd client && npm install",
        "bundle": "npm run bundle-client && npm run bundle-webviews && npm run copy-static-assets",
        "bundle-client": "esbuild ./client/src/extension.ts --bundle --outfile=dist/client.js --external:vscode --format=cjs --platform=node --minify",
        "bundle-webviews": "mkdir -p dist/webview && esbuild ./client/src/webview/DomainsApp.tsx --bundle --outfile=dist/webview/domains.js --format=iife --platform=browser --minify && esbuild ./client/src/webview/ServicesApp.tsx --bundle --outfile=dist/webview/services.js --format=iife --platform=browser --minify",
        "copy-static-assets": "mkdir -p dist/styles dist/@vscode/codicons/dist && cp client/src/ui/styles/treeStyles.css dist/styles/ && cp -r client/node_modules/@vscode/codicons/dist/* dist/@vscode/codicons/dist/",
        "dev": "npm run copy-static-assets && npm run dev-client & npm run dev-webviews",
        "dev-client": "esbuild ./client/src/extension.ts --bundle --outfile=dist/client.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
        "dev-webviews": "mkdir -p dist/webview && esbuild ./client/src/webview/DomainsApp.tsx --bundle --outfile=dist/webview/domains.js --format=iife --platform=browser --sourcemap --watch & esbuild ./client/src/webview/ServicesApp.tsx --bundle --outfile=dist/webview/services.js --format=iife --platform=browser --sourcemap --watch",
        "debug": "npm run copy-static-assets && npm run debug-webviews && npm run debug-client",
        "debug-client": "esbuild ./client/src/extension.ts --bundle --outfile=dist/client.js --external:vscode --format=cjs --platform=node --sourcemap",
        "debug-webviews": "mkdir -p dist/webview && esbuild ./client/src/webview/DomainsApp.tsx --bundle --outfile=dist/webview/domains.js --format=iife --platform=browser --sourcemap && esbuild ./client/src/webview/ServicesApp.tsx --bundle --outfile=dist/webview/services.js --format=iife --platform=browser --sourcemap"
    },
    "devDependencies": {
        "@eslint/js": "^9.13.0",
        "@stylistic/eslint-plugin": "^2.9.0",
        "@types/jest": "^30.0.0",
        "@types/node": "^20",
        "@vscode/vsce": "^3.6.2",
        "esbuild": "^0.25.10",
        "eslint": "^9.13.0",
        "jest": "^30.2.0",
        "ts-jest": "^29.4.4",
        "tsx": "^4.20.6",
        "typescript": "^5.6.2",
        "typescript-eslint": "^8.11.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "configuration": {
            "title": "Craft Language",
            "properties": {
                "craft.server.url": {
                    "type": "string",
                    "default": "http://localhost:8080",
                    "description": "URL of the Craft server for diagram generation",
                    "pattern": "^https?:\\/\\/.+",
                    "patternErrorMessage": "Must be a valid HTTP or HTTPS URL"
                },
                "craft.server.timeout": {
                    "type": "number",
                    "default": 30000,
                    "minimum": 5000,
                    "maximum": 120000,
                    "description": "Timeout for server requests in milliseconds (5-120 seconds)"
                },
                "craft.downloadPath": {
                    "type": "string",
                    "default": "",
                    "description": "Default path for downloading diagram files. If empty, user will be prompted to choose location for each download."
                },
                "craft.logging.level": {
                    "type": "string",
                    "enum": [
                        "off",
                        "error",
                        "warn",
                        "info",
                        "debug",
                        "trace"
                    ],
                    "default": "warn",
                    "description": "Logging verbosity level. Use 'debug' or 'trace' for development and troubleshooting."
                },
                "craft.lsp.executablePath": {
                    "type": "string",
                    "default": "",
                    "description": "Path to the craft language server binary. When set, the managed download is skipped and this binary is used directly. Leave empty to use the automatically downloaded binary."
                },
                "craft.mermaid.theme": {
                    "type": "string",
                    "enum": ["default", "dark", "forest", "neutral"],
                    "default": "default",
                    "description": "Mermaid theme for in-editor previews."
                }
            }
        },
        "languages": [
            {
                "id": "craft",
                "aliases": [
                    "Craft Language",
                    "craft"
                ],
                "extensions": [
                    ".craft"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "craft",
                "scopeName": "source.craft",
                "path": "./syntaxes/craft.tmLanguage.json"
            }
        ],
        "semanticTokenTypes": [
            {
                "id": "craft-flow-keyword",
                "superType": "keyword",
                "description": "Flow control keywords like use_case, when"
            },
            {
                "id": "craft-services-keyword",
                "superType": "keyword",
                "description": "Services block keyword"
            },
            {
                "id": "craft-arch-keyword",
                "superType": "keyword",
                "description": "Architecture block keyword"
            },
            {
                "id": "craft-exposure-keyword",
                "superType": "keyword",
                "description": "Exposure block keyword"
            },
            {
                "id": "craft-domain-keyword",
                "superType": "keyword",
                "description": "Domain block keyword"
            },
            {
                "id": "craft-actor-keyword",
                "superType": "keyword",
                "description": "Actor block keyword"
            },
            {
                "id": "craft-actors-keyword",
                "superType": "keyword",
                "description": "Actors block keyword"
            },
            {
                "id": "craft-actor-type",
                "superType": "keyword",
                "description": "Actor type keywords (user, system, service)"
            },
            {
                "id": "craft-contexts-property",
                "superType": "property",
                "description": "Contexts property keyword"
            },
            {
                "id": "craft-language-property",
                "superType": "property",
                "description": "Language property keyword"
            },
            {
                "id": "craft-data-stores-property",
                "superType": "property",
                "description": "Data stores property keyword"
            },
            {
                "id": "craft-deployment-property",
                "superType": "property",
                "description": "Deployment property keyword"
            },
            {
                "id": "craft-to-property",
                "superType": "property",
                "description": "To property keyword"
            },
            {
                "id": "craft-through-property",
                "superType": "property",
                "description": "Through property keyword"
            },
            {
                "id": "craft-presentation-section",
                "superType": "property",
                "description": "Presentation section keyword"
            },
            {
                "id": "craft-gateway-section",
                "superType": "property",
                "description": "Gateway section keyword"
            },
            {
                "id": "craft-asks-verb",
                "superType": "function",
                "description": "Asks action verb"
            },
            {
                "id": "craft-notifies-verb",
                "superType": "function",
                "description": "Notifies action verb"
            },
            {
                "id": "craft-listens-verb",
                "superType": "function",
                "description": "Listens action verb"
            },
            {
                "id": "craft-returns-verb",
                "superType": "function",
                "description": "Returns action verb"
            },
            {
                "id": "craft-service-name",
                "superType": "class",
                "description": "Service names"
            },
            {
                "id": "craft-domain-name",
                "superType": "namespace",
                "description": "Domain definition names"
            },
            {
                "id": "craft-domain-list",
                "superType": "namespace",
                "description": "Domain list values"
            },
            {
                "id": "craft-data-store-name",
                "superType": "variable",
                "description": "Data store names"
            },
            {
                "id": "craft-context-name",
                "superType": "type",
                "description": "Bounded context names"
            },
            {
                "id": "craft-component-name",
                "superType": "type",
                "description": "Component names"
            },
            {
                "id": "craft-exposure-name",
                "superType": "interface",
                "description": "Exposure names"
            },
            {
                "id": "craft-language-value",
                "superType": "enumMember",
                "description": "Language values"
            },
            {
                "id": "craft-actor-name",
                "superType": "parameter",
                "description": "Actor names (in use cases)"
            },
            {
                "id": "craft-actor-definition",
                "superType": "parameter",
                "description": "Actor definition names"
            },
            {
                "id": "craft-regular-verb",
                "superType": "function",
                "description": "Regular verbs"
            },
            {
                "id": "craft-phrase-word",
                "superType": "variable",
                "description": "Words in phrases"
            },
            {
                "id": "craft-connector-word",
                "superType": "operator",
                "description": "Connector words (a, an, the, to, from, etc.)"
            },
            {
                "id": "craft-deployment-type",
                "superType": "enumMember",
                "description": "Deployment type"
            },
            {
                "id": "craft-deployment-target",
                "superType": "enumMember",
                "description": "Deployment target"
            },
            {
                "id": "craft-usecase-string",
                "superType": "string",
                "description": "Use case names"
            },
            {
                "id": "craft-event-string",
                "superType": "event",
                "description": "Event strings"
            },
            {
                "id": "craft-regular-string",
                "superType": "string",
                "description": "Regular strings"
            },
            {
                "id": "craft-comment",
                "superType": "comment",
                "description": "Comments"
            },
            {
                "id": "craft-boolean",
                "superType": "enumMember",
                "description": "Boolean values (true, false)"
            },
            {
                "id": "craft-braces",
                "superType": "operator",
                "description": "Braces"
            },
            {
                "id": "craft-comma",
                "superType": "operator",
                "description": "Commas"
            },
            {
                "id": "craft-percentage",
                "superType": "number",
                "description": "Percentage"
            },
            {
                "id": "craft-parenthesis",
                "superType": "operator",
                "description": "Parenthesis"
            },
            {
                "id": "craft-deployment-arrow",
                "superType": "operator",
                "description": "Deployment Arrow"
            }
        ],
        "semanticTokenModifiers": [],
        "semanticTokenScopes": [
            {
                "language": "craft",
                "scopes": {
                    "craft-flow-keyword": [
                        "keyword.control"
                    ],
                    "craft-services-keyword": [
                        "keyword.control"
                    ],
                    "craft-arch-keyword": [
                        "keyword.control"
                    ],
                    "craft-exposure-keyword": [
                        "keyword.control"
                    ],
                    "craft-domain-keyword": [
                        "keyword.control"
                    ],
                    "craft-actor-keyword": [
                        "keyword.control"
                    ],
                    "craft-actors-keyword": [
                        "keyword.control"
                    ],
                    "craft-contexts-property": [
                        "keyword.other"
                    ],
                    "craft-language-property": [
                        "keyword.other"
                    ],
                    "craft-data-stores-property": [
                        "keyword.other"
                    ],
                    "craft-deployment-property": [
                        "keyword.other"
                    ],
                    "craft-to-property": [
                        "keyword.other"
                    ],
                    "craft-through-property": [
                        "keyword.other"
                    ],
                    "craft-presentation-section": [
                        "keyword.other"
                    ],
                    "craft-gateway-section": [
                        "keyword.other"
                    ],
                    "craft-asks-verb": [
                        "entity.name.function"
                    ],
                    "craft-notifies-verb": [
                        "entity.name.function"
                    ],
                    "craft-listens-verb": [
                        "entity.name.function"
                    ],
                    "craft-returns-verb": [
                        "entity.name.function"
                    ],
                    "craft-regular-verb": [
                        "entity.name.function"
                    ],
                    "craft-actor-definition": [
                        "variable.parameter.craft"
                    ],
                    "craft-context-name": [
                        "entity.name.type"
                    ],
                    "craft-service-name": [
                        "entity.name.class"
                    ],
                    "craft-component-name": [
                        "entity.name.type"
                    ],
                    "craft-exposure-name": [
                        "entity.name.interface"
                    ],
                    "craft-data-store-name": [
                        "variable.other"
                    ],
                    "craft-deployment-type": [
                        "variable.other.enummember"
                    ],
                    "craft-domain-name": [
                        "entity.name.namespace"
                    ],
                    "craft-domain-list": [
                        "entity.name.namespace"
                    ],
                    "craft-actor-name": [
                        "variable.parameter.craft"
                    ],
                    "craft-deployment-target": [
                        "variable.other.enummember"
                    ],
                    "craft-actor-type": [
                        "keyword.other"
                    ],
                    "craft-language-value": [
                        "variable.other.enummember"
                    ],
                    "craft-usecase-string": [
                        "string.quoted.double"
                    ],
                    "craft-event-string": [
                        "string.other"
                    ],
                    "craft-regular-string": [
                        "string.quoted.double"
                    ],
                    "craft-connector-word": [
                        "keyword.operator"
                    ],
                    "craft-comma": [
                        "punctuation.separator"
                    ],
                    "craft-parenthesis": [
                        "punctuation.bracket"
                    ],
                    "craft-braces": [
                        "punctuation.definition.block"
                    ],
                    "craft-deployment-arrow": [
                        "keyword.operator"
                    ],
                    "craft-comment": [
                        "comment.line.double-slash"
                    ],
                    "craft-boolean": [
                        "constant.language"
                    ],
                    "craft-percentage": [
                        "constant.numeric"
                    ]
                }
            }
        ],
        "configurationDefaults": {
            "[craft]": {
                "editor.semanticHighlighting.enabled": true
            }
        },
        "commands": [
            {
                "command": "craft.previewC4",
                "title": "Craft: Preview C4 Diagram",
                "category": "Craft"
            },
            {
                "command": "craft.previewSelectedC4",
                "title": "Craft: Preview Selected C4 Diagram",
                "category": "Craft"
            },
            {
                "command": "craft.previewDomain",
                "title": "Craft: Preview Domain Diagram",
                "category": "Craft"
            },
            {
                "command": "craft.previewDomainsFromSelection",
                "title": "Craft: Preview Domain Diagram from selection",
                "category": "Craft"
            },
            {
                "command": "craft.previewMermaidDomain",
                "title": "Craft: Preview Mermaid Domain",
                "category": "Craft"
            },
            {
                "command": "craft.previewMermaidSequence",
                "title": "Craft: Preview Mermaid Sequence",
                "category": "Craft"
            },
            {
                "command": "craft.previewMermaidC4",
                "title": "Craft: Preview Mermaid C4",
                "category": "Craft"
            },
            {
                "command": "craft.openSettings",
                "title": "Craft: Open Settings",
                "category": "Craft"
            },
            {
                "command": "craft.selectAllDomains",
                "title": "Select All Domains",
                "icon": "$(checklist)"
            },
            {
                "command": "craft.selectNoneDomains",
                "title": "Clear Domain Selection",
                "icon": "$(clear-all)"
            },
            {
                "command": "craft.selectCurrentFileDomains",
                "title": "Select Current File Domains",
                "icon": "$(file)"
            },
            {
                "command": "craft.selectAllServices",
                "title": "Select All Services",
                "icon": "$(checklist)"
            },
            {
                "command": "craft.selectNoneServices",
                "title": "Clear Service Selection",
                "icon": "$(clear-all)"
            },
            {
                "command": "craft.refreshDomains",
                "title": "Refresh Domains",
                "icon": "$(refresh)"
            },
            {
                "command": "craft.previewDomains",
                "title": "Preview Domain Diagram",
                "icon": "$(preview)"
            },
            {
                "command": "craft.refreshServices",
                "title": "Refresh Services",
                "icon": "$(refresh)"
            },
            {
                "command": "craft.previewServices",
                "title": "Preview Services Diagram",
                "icon": "$(preview)"
            },
            {
                "command": "craft.toggleDomainOptions",
                "title": "Toggle Domain Diagram Options",
                "icon": "$(settings-gear)"
            },
            {
                "command": "craft.toggleServiceOptions",
                "title": "Toggle Service Diagram Options",
                "icon": "$(settings-gear)"
            }
        ],
        "keybindings": [
            {
                "command": "craft.previewC4",
                "key": "ctrl+shift+c"
            },
            {
                "command": "craft.previewDomain",
                "key": "ctrl+shift+d"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "dslDomainContainer",
                    "title": "DSL Domains",
                    "icon": "resources/craft_icon.svg"
                }
            ]
        },
        "views": {
            "dslDomainContainer": [
                {
                    "id": "dslDomainView",
                    "name": "Domain Manager",
                    "type": "webview",
                    "icon": "resources/craft_icon.svg"
                },
                {
                    "id": "dslServicesView",
                    "name": "Services",
                    "type": "webview",
                    "icon": "resources/craft_icon.svg"
                }
            ]
        },
        "menus": {
            "view/title": [
                {
                    "command": "craft.selectAllDomains",
                    "when": "view == dslDomainView",
                    "group": "navigation@1"
                },
                {
                    "command": "craft.selectNoneDomains",
                    "when": "view == dslDomainView",
                    "group": "navigation@2"
                },
                {
                    "command": "craft.selectCurrentFileDomains",
                    "when": "view == dslDomainView",
                    "group": "navigation@3"
                },
                {
                    "command": "craft.selectAllServices",
                    "when": "view == dslServicesView",
                    "group": "navigation@1"
                },
                {
                    "command": "craft.selectNoneServices",
                    "when": "view == dslServicesView",
                    "group": "navigation@2"
                },
                {
                    "command": "craft.previewDomains",
                    "when": "view == dslDomainView",
                    "group": "navigation@4"
                },
                {
                    "command": "craft.toggleDomainOptions",
                    "when": "view == dslDomainView",
                    "group": "navigation@5"
                },
                {
                    "command": "craft.refreshDomains",
                    "when": "view == dslDomainView",
                    "group": "navigation@6"
                },
                {
                    "command": "craft.previewServices",
                    "when": "view == dslServicesView",
                    "group": "navigation@3"
                },
                {
                    "command": "craft.toggleServiceOptions",
                    "when": "view == dslServicesView",
                    "group": "navigation@4"
                },
                {
                    "command": "craft.refreshServices",
                    "when": "view == dslServicesView",
                    "group": "navigation@5"
                }
            ]
        }
    }
}
